# Normalize all text files to LF on commit
* text=auto eol=lf

# Gradle wrapper shell script must be LF — will break on CI with CRLF
gradlew text eol=lf

# Windows batch files must be CRLF
*.bat text eol=crlf

# Explicitly binary — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.jar binary
*.apk binary
*.aab binary
*.aar binary
*.keystore binary
*.jks binary
